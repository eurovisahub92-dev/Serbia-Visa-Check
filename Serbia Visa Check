<script>
async function checkVisa() {
  const visaNumber = document.getElementById('visaInput').value.trim();
  const resultDiv = document.getElementById('result');

  if (!visaNumber) {
    resultDiv.innerHTML = '⚠️ Please enter a visa reference number';
    resultDiv.style.color = 'orange';
    return;
  }

  try {
    const response = await fetch('visas.json');
    const visas = await response.json();

    const visa = visas.find(v => v.ref === visaNumber);

    if (visa) {
      resultDiv.innerHTML = `
        ✅ Visa VALID <br>
        Name: ${visa.name} <br>
        Expiry: ${visa.expiry}
      `;
      resultDiv.style.color = 'green';
    } else {
      resultDiv.innerHTML = '❌ Visa not found';
      resultDiv.style.color = 'red';
    }

  } catch (error) {
    resultDiv.innerHTML = '⚠️ Error loading data';
  }
}
</script>
